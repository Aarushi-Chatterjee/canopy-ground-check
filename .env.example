# Copy this file to .env and fill in real values.
# NEVER commit .env — only commit .env.example with placeholder values.

# Formspree endpoint for full questionnaire submission (Stage 6 result screen)
# Get your endpoint from: https://formspree.io/forms
# Set Allowed Domains in Formspree dashboard to your Vercel URL only.
VITE_FORMSPREE_GROUND_CHECK=https://formspree.io/f/YOUR_FORM_ID_HERE

# Formspree endpoint for early access email-only collection (Nav modal)
VITE_FORMSPREE_EARLY_ACCESS=https://formspree.io/f/YOUR_EARLY_ACCESS_FORM_ID_HERE
